{
  "name": "animate",
  "version": "0.1.0",
  "description": "Desktop 2D motion editor",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.27",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@webtoon/psd": "^0.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.5.8",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "image-size": "^1.1.0",
    "immer": "^11.1.4",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.0.0",
    "pako": "^2.1.0",
    "pixi.js": "^8.6.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.animate.app",
    "productName": "Animate",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static",
        "to": "ffmpeg-static",
        "filter": [
          "ffmpeg",
          "ffmpeg.exe",
          "index.js",
          "package.json"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
